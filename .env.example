# Copy this to .env and fill in your values
# Never commit .env to git

# --- AI ---
GEMINI_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=your_claude_key_here
GROQ_API_KEY=your_groq_key_here
LLM_PROVIDER=groq   # gemini | claude | groq | mock | none

# --- App ---
APP_ENV=development          # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# --- Data ---
DATA_DIR=./data
CUTOFFS_DIR=./data/cutoffs
DB_PATH=./data/jee_counselor.duckdb
SESSIONS_DB_PATH=./data/sessions.db

# --- Cache ---
CACHE_DIR=./data/cache
CACHE_TTL_SECONDS=3600

# --- LLM ---
# Set to false to skip LLM explanations (faster, for testing)
ENABLE_LLM_EXPLANATIONS=true
LLM_MODEL=llama3-8b-8192   # e.g., llama3-8b-8192 for Groq, or claude-sonnet-4-6 for Anthropic
